   ├── __init__.py\n│   ├── test_health.py\n│   └── test_example.py\n├── docs/\n│   └── README.md\n├── scripts/\n│   └── setup.sh\n├── requirements.txt\n├── pyproject.toml\n├── .env.example\n├── .gitignore\n└── README.md\n```\n\n### 1. 主应用文件\n\n```python\n# filename: src/main.py\n"""\nFastAPI 应用主入口\n"""\nfrom fastapi import FastAPI\nfrom fastapi.middleware.cors import CORSMiddleware\n\nfrom src.api.routes import health, example\nfrom src.core.config import settings\nfrom src.core.exceptions import add_exception_handlers\n\n\ndef create_application() -> FastAPI:\n    """\n    创建 FastAPI 应用实例\n    """\n    app = FastAPI(\n        title=settings.PROJECT_NAME,\n        version=settings.VERSION,\n        description=settings.DESCRIPTION,\n        docs_url="/docs",\n        redoc_url="/redoc",\n        openapi_url="/openapi.json"\n    )\n\n    # 添加 CORS 中间件\n    if settings.BACKEND_CORS_ORIGINS:\n        app.add_middleware(\n            CORSMiddleware,\n            allow_origins=[str(origin) for origin in settings.BACKEND_CORS_ORIGINS],\n            allow_credentials=True,\n            allow_methods=["*"],\n            allow_headers=["*"],\n        )\n\n    # 添加异常处理器\n    add_exception_handlers(app)\n\n    # 注册路由\n    app.include_router(health.router, prefix="/api", tags=["health"])\n    app.include_router(example.router, prefix="/api/v1", tags=["example"])\n\n    return app\n\n\napp = create_application()\n\n\n@app.get("/")\nasync def root():\n    """\n    根端点，提供应用信息\n    """\n    return {\n        "name": settings.PROJECT_NAME,\n        "version": settings.VERSION,\n        "description": settings.DESCRIPTION,\n        "docs": "/docs",\n        "redoc": "/redoc"\n    }\n```\n\n### 2. 配置文件\n\n```python\n# filename: src/core/config.py\n"""\n应用配置设置\n"""\nimport os\nfrom typing import List, Optional, Union\n\nfrom pydantic import AnyHttpUrl, BaseSettings, validator\n\n\nclass Settings(BaseSettings):\n    """\n    应用设置类，从环境变量加载配置\n    """\n    # 基础配置\n    PROJECT_NAME: str = "My FastAPI Service"\n    VERSION: str = "1.0.0"\n    DESCRIPTION: str = "A FastAPI service with best practices"\n    API_V1_STR: str = "/api/v1"\n    \n    # 服务器配置\n    HOST: str = "0.0.0.0"\n    PORT: int = 8000\n    DEBUG: bool = False\n    \n    # CORS 配置\n    BACKEND_CORS_ORIGINS: List[AnyHttpUrl] = []\n    \n    @validator("BACKEND_CORS_ORIGINS", pre=True)\n    def assemble_cors_origins(cls, v: Union[str, List[str]]) -> Union[List[str], str]:\n        if isinstance(v, str) and not v.startswith("["):\n            return [i.strip() for i in v.split(",")]\n        elif isinstance(v, (list, str)):\n            return v\n        raise ValueError(v)\n    \n    # 数据库配置（示例）\n    DATABASE_URL: Optional[str] = None\n    \n    # 安全配置\n    SECRET_KEY: str = os.getenv("SECRET_KEY", "your-secret-key-change-in-production")\n    ACCESS_TOKEN_EXPIRE_MINUTES: int = 30\n    \n    class Config:\n        case_sensitive = True\n        env_file = ".env"\n\n\n# 创建全局设置实例\nsettings = Settings()\n```\n\n### 3. 异常处理\n\n```python\n# filename: src/core/exceptions.py\n"""\n全局异常处理器\n"""\nfrom typing import Any, Dict\n\nfrom fastapi import FastAPI, HTTPException, Request\nfrom fastapi.responses import JSONResponse\nfrom starlette import status\n\n\nclass CustomHTTPException(HTTPException):\n    """自定义 HTTP 异常"""\n    def __init__(\n        self,\n        status_code: int,\n        detail: str = None,\n        headers: Dict[str, Any] = None,\n    ):\n        super().__init__(status_code=status_code, detail=detail, headers=headers)\n\n\nasync def http_exception_handler(request: Request, exc: HTTPException) -> JSONResponse:\n    """HTTP 异常处理器"""\n    return JSONResponse(\n        status_code=exc.status_code,\n        content={\n            "success": False,\n            "error": {\n                "code": exc.status_code,\n                "message": exc.detail,\n                "path": str(request.url.path)\n            }\n        },\n        headers=exc.headers,\n    )\n\n\nasync def validation_exception_handler(request: Request, exc: Exception) -> JSONResponse:\n    """验证异常处理器"""\n    return JSONResponse(\n        status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n        content={\n            "success": False,\n            "error": {\n                "code": status.HTTP_422_UNPROCESSABLE_ENTITY,\n                "message": str(exc),\n                "path": str(request.url.path)\n            }\n        }\n    )\n\n\nasync def general_exception_handler(request: Request, exc: Exception) -> JSONResponse:\n    """通用异常处理器"""\n    return JSONResponse(\n        status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,\n        content={\n            "success": False,\n            "error": {\n                "code": status.HTTP_500_INTERNAL_SERVER_ERROR,\n                "message": "Internal server error",\n                "path": str(request.url.path)\n            }\n        }\n    )\n\n\ndef add_exception_handlers(app: FastAPI) -> None:\n    """向应用添加异常处理器"""\n    app.add_exception_handler(HTTPException, http_exception_handler)\n    app.add_exception_handler(Exception, general_exception_handler)\n```\n\n### 4. 健康检查路由\n\n```python\n# filename: src/api/routes/health.py\n"""\n健康检查路由\n"""\nfrom datetime import datetime\nfrom typing import Dict\n\nfrom fastapi import APIRouter, Depends\nfrom fastapi.responses import JSONResponse\n\nrouter = APIRouter()\n\n\n@router.get("/health", response_model=Dict[str, str])\nasync def health_check() -> Dict[str, str]:\n    """\n    健康检查端点\n    \n    Returns:\n        包含应用状态信息的字典\n    """\n    return {\n        "status": "healthy",\n        "timestamp": datetime.now().isoformat(),\n        "service": "fastapi-service"\n    }\n\n\n@router.get("/health/detailed", response_model=Dict[str, str])\nasync def detailed_health_check() -> Dict[str, str]:\n    """\n    详细健康检查端点\n    \n    Returns:\n        包含详细状态信息的字典\n    """\n    return {\n        "status": "healthy",\n        "timestamp": datetime.now().isoformat(),\n        "service": "fastapi-service",\n        "version": "1.0.0",\n        "uptime": "running"\n    }\n```\n\n### 5. 示例路由\n\n```python\n# filename: src/api/routes/example.py\n"""\n示例路由\n"""\nfrom typing import Dict, List, Optional\n\nfrom fastapi import APIRouter, HTTPException, Query\n\nfrom src.models.schemas import Item, ItemCreate, ItemUpdate\n\nrouter = APIRouter()\n\n# 模拟数据库\nfake_items_db = []\n\n\n@router.get("/items", response_model=List[Item])\nasync def read_items(\n    skip: int = Query(0, ge=0, description="跳过多少条记录"),\n    limit: int = Query(100, ge=1, le=1000, description="返回多少条记录")\n) -> List[Item]:\n    """\n    获取项目列表\n    \n    Args:\n        skip: 跳过的记录数\n        limit: 返回的记录数限制\n    \n    Returns:\n        项目列表\n    """\n    return fake_items_db[skip: skip + limit]\n\n\n@router.get("/items/{item_id}", response_model=Item)\nasync def read_item(item_id: int) -> Item:\n    """\n    根据 ID 获取项目\n    \n    Args:\n        item_id: 项目 ID\n    \n    Returns:\n        项目信息\n    \n    Raises:\n        HTTPException: 项目不存在时抛出 404 错误\n    """\n    for item in fake_items_db:\n        if item.id == item_id:\n            return item\n    raise HTTPException(status_code=404, detail="Item not found")\n\n\n@router.post("/items", response_model=Item, status_code=201)\nasync def create_item(item: ItemCreate) -> Item:\n    """\n    创建新项目\n    \n    Args:\n        item: 要创建的项目数据\n    \n    Returns:\n        创建的项目信息\n    """\n    new_item = Item(\n        id=len(fake_items_db) + 1,\n        **item.dict()\n    )\n    fake_items_db.append(new_item)\n    return new_item\n\n\n@router.put("/items/{item_id}", response_model=Item)\nasync def update_item(item_id: int, item_update: ItemUpdate) -> Item:\n    """\n    更新项目\n    \n    Args:\n        item_id: 项目 ID\n        item_update: 要更新的项目数据\n    \n    Returns:\n        更新后的项目信息\n    \n    Raises:\n        HTTPException: 项目不存在时抛出 404 错误\n    """\n    for idx, item in enumerate(fake_items_db):\n        if item.id == item_id:\n            update_data = item_update.dict(exclude_unset=True)\n            updated_item = item.copy(update=update_data)\n            fake_items_db[idx] = updated_item\n            return updated_item\n    raise HTTPException(status_code=404, detail="Item not found")\n\n\n@router.delete("/items/{item_id}", status_code=204)\nasync def delete_item(item_id: int) -> None:\n    """\n    删除项目\n    \n    Args:\n        item_id: 项目 ID\n    \n    Raises:\n        HTTPException: 项目不存在时抛出 404 错误\n    """\n    for idx, item in enumerate(fake_items_db):\n        if item.id == item_id:\n            fake_items_db.pop(idx)\n            return\n    raise HTTPException(status_code=404, detail="Item not found")\n```\n\n### 6. 数据模型\n\n```python\n# filename: src/models/schemas.py\n"""\nPydantic 数据模型\n"""\nfrom datetime import datetime\nfrom typing import Optional\n\nfrom pydantic import BaseModel, Field\n\n\nclass ItemBase(BaseModel):\n    """项目基础模型"""\n    name: str = Field(..., min_length=1, max_length=100, description="项目名称")\n    description: Optional[str] = Field(None, max_length=500, description="项目描述")\n    price: float = Field(..., ge=0, description="价格")\n\n\nclass ItemCreate(ItemBase):\n    """创建项目模型"""\n    pass\n\n\nclass ItemUpdate(BaseModel):\n    """更新项目模型"""\n    name: Optional[str] = Field(None, min_length=1, max_length=100)\n    description: Optional[str] = Field(None, max_length=500)\n    price: Optional[float] = Field(None, ge=0)\n\n\nclass Item(ItemBase):\n    """项目模型"""\n    id: int = Field(..., description="项目 ID")\n    created_at: datetime = Field(default_factory=datetime.now, description="创建时间")\n    updated_at: datetime = Field(default_factory=datetime.now, description="更新时间")\n    \n    class Config:\n        orm_mode = True\n        schema_extra = {\n            "example": {\n                "id": 1,\n                "name": "示例项目",\n                "description": "这是一个示例项目",\n                "price": 99.99,\n                "created_at": "2024-01-01T00:00:00",\n                "updated_at": "2024-01-01T00:00:00"\n            }\n        }\n```\n\n### 7. 依赖管理文件\n\n```txt\n# filename: requirements.txt\nfastapi==0.104.1\nuvicorn[standard]==0.24.0\npydantic==2.5.0\npython-dotenv==1.0.0\npytest==7.4.3\nhttpx==0.25.1\n```\n\n### 8. pyproject.toml 配置文件\n\n```toml\n# filename: pyproject.toml\n[project]\nname = "my-fastapi-service"\nversion = "1.0.0"\ndescription = "A FastAPI service with best practices"\nauthors = [\n    {name = "Your Name", email = "your.email@example.com"}\n]\nreadme = "README.md"\nrequires-python = ">=3.8"\ndependencies = [\n    "fastapi>=0.104.0",\n    "uvicorn[standard]>=0.24.0",\n    "pydantic>=2.5.0",\n    "python-dotenv>=1.0.0"\n]\n\n[project.optional-dependencies]\ndev = [\n    "pytest>=7.4.0",\n    "httpx>=0.25.0",\n    "black>=23.0.0",\n    "isort>=5.12.0",\n    "mypy>=1.7.0"\n]\n\n[build-system]\nrequires = ["setuptools>=61.0", "wheel"]\nbuild-backend = "setuptools.build_meta"\n\n[tool.black]\nline-length = 88\ntarget-version = [\'py38\', \'py39\', \'py310\', \'py311\']\n\n[tool.isort]\nprofile = "black"\nmulti_line_output = 3\ninclude_trailing_comma = true\nforce_grid_wrap = 0\nuse_parentheses = true\nensure_newline_before_comments = true\n```\n\n### 9. 环境变量示例文件\n\n```env\n# filename: .env.example\n# 应用配置\nPROJECT_NAME="My FastAPI Service"\nVERSION="1.0.0"\nDESCRIPTION="A FastAPI service with best practices"\n\n# 服务器配置\nHOST="0.0.0.0"\nPORT=8000\nDEBUG=false\n\n# CORS 配置（逗号分隔）\nBACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"\n\n# 数据库配置\nDATABASE_URL="postgresql://user:password@localhost/dbname"\n\n# 安全配置\nSECRET_KEY="your-secret-key-change-in-production"\nACCESS_TOKEN_EXPIRE_MINUTES=30\n```\n\n### 10. Git 忽略文件\n\n```gitignore\n# filename: .gitignore\n# Python\n__pycache__/\n*.py[cod]\n*$py.class\n*.so\n.Python\nbuild/\ndevelop-eggs/\ndist/\ndownloads/\neggs/\n.eggs/\nlib/\nlib64/\nparts/\nsdist/\nvar/\nwheels/\n*.egg-info/\n.installed.cfg\n*.egg\n\n# Virtual Environment\nvenv/\nenv/\nENV/\n.venv/\n\n# IDE\n.vscode/\n.idea/\n*.swp\n*.swo\n*~\n\n# Environment variables\n.env\n.env.local\n\n# Logs\n*.log\nlogs/\n\n# Testing\n.coverage\nhtmlcov/\n.pytest_cache/\n\n# OS\n.DS_Store\nThumbs.db\n\n# Documentation\ndocs/_build/\n```\n\n### 11. 主 README 文件\n\n```markdown\n# filename: README.md\n# My FastAPI Service\n\n一个基于 FastAPI 构建的现代 Web 服务，遵循最佳实践。\n\n## 特性\n\n- 🚀 使用 FastAPI 构建，高性能\n- 📦 模块化项目结构\n- 🔒 内置 CORS 支持\n- 🛡️ 异常处理和验证\n- 📝 完整的 API 文档\n- 🧪 测试支持\n- ⚙️ 配置管理\n\n## 快速开始\n\n### 前置要求\n\n- Python 3.8+\n- pip 或 poetry\n\n### 安装\n\n1. 克隆项目\n```bash\ngit clone <repository-url>\ncd my_fastapi_service\n```\n\n2. 创建虚拟环境\n```bash\npython -m venv venv\nsource venv/bin/activate  # Linux/Mac\n# 或\nvenv\\Scripts\\activate  # Windows\n```\n\n3. 安装依赖\n```bash\npip install -r requirements.txt\n```\n\n4. 配置环境变量\n```bash\ncp .env.example .env\n# 编辑 .env 文件配置你的设置\n```\n\n### 运行\n\n#### 开发模式\n```bash\nuvicorn src.main:app --reload --host 0.0.0.0 --port 8000\n```\n\n#### 生产模式\n```bash\nuvicorn src.main:app --host 0.0.0.0 --port 8000\n```\n\n### 访问 API 文档\n\n- Swagger UI: http://localhost:8000/docs\n- ReDoc: http://localhost:8000/redoc\n\n## API 端点\n\n### 健康检查\n- `GET /api/health` - 基本健康检查\n- `GET /api/health/detailed` - 详细健康检查\n\n### 示例项目\n- `GET /api/v1/items` - 获取项目列表\n- `GET /api/v1/items/{item_id}` - 获取单个项目\n- `POST /api/v1/items` - 创建项目\n- `PUT /api/v1/items/{item_id}` - 更新项目\n- `DELETE /api/v1/items/{item_id}` - 删除项目\n\n## 项目结构\n\n```\nmy_fastapi_service/\n├── src/                    # 源代码\n│   ├── api/               # API 路由\n│   ├──', additional_kwargs={'refusal': None}, response_metadata={'token_usage': {'completion_tokens': 4096, 'prompt_tokens': 3668, 'total_tokens': 7764, 'completion_tokens_details': None, 'prompt_tokens_details': None}, 'model_provider': 'openai', 'model_name': 'deepseek-v3.2', 'system_fingerprint': None, 'id': '6d070b99-cc97-4cb8-9104-b0a3b14fc1f4', 'finish_reason': 'stop', 'logprobs': None}, id='lc_run--019d2fc8-df60-79d2-9651-4c148d29d35c-0', tool_calls=[], inv